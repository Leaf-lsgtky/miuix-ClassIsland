<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- 课程名称 -->
    <TextView
        android:id="@+id/island_course_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="17sp"
        android:textStyle="bold"
        android:textColor="#E6FFFFFF"
        android:layout_marginBottom="10dp" />

    <!-- 时间 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="3dp">

        <TextView
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:text="时间"
            android:textSize="13sp"
            android:textColor="#61FFFFFF" />

        <TextView
            android:id="@+id/island_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#99FFFFFF" />
    </LinearLayout>

    <!-- 节次 -->
    <LinearLayout
        android:id="@+id/island_section_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="3dp">

        <TextView
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:text="节次"
            android:textSize="13sp"
            android:textColor="#61FFFFFF" />

        <TextView
            android:id="@+id/island_section"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#99FFFFFF" />
    </LinearLayout>

    <!-- 地点 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="3dp">

        <TextView
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:text="地点"
            android:textSize="13sp"
            android:textColor="#61FFFFFF" />

        <TextView
            android:id="@+id/island_location"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#99FFFFFF" />
    </LinearLayout>

    <!-- 教师 -->
    <LinearLayout
        android:id="@+id/island_teacher_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:text="教师"
            android:textSize="13sp"
            android:textColor="#61FFFFFF" />

        <TextView
            android:id="@+id/island_teacher"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="14sp"
            android:textColor="#99FFFFFF" />
    </LinearLayout>

    <!-- 详情按钮 -->
    <TextView
        android:id="@+id/island_action_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:background="@drawable/bg_island_button"
        android:paddingHorizontal="20dp"
        android:paddingVertical="8dp"
        android:text="详情"
        android:textSize="14sp"
        android:textColor="#FF6CB0FF" />

</LinearLayout>
